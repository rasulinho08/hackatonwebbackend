# Köçür: bu faylı .env adı ilə kopyala və dəyərləri doldur (.env git-ə düşmür).
# Komanda:  copy .env.example .env   (Windows)

# --- Supabase PostgreSQL (Session pooler, port 5432) ---
DB_HOST=aws-1-ap-northeast-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.YOUR_PROJECT_REF
DB_PASSWORD=your-database-password
DB_SSL_MODE=require

# --- Local PostgreSQL üçün nümunə (Supabase istəmirsənsə) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=soc
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_SSL_MODE=prefer

# Local Spring (default port 8080; SERVER_PORT overrides if set)
SERVER_PORT=8080
# PaaS often injects PORT — Docker image sets SPRING_PROFILES_ACTIVE=prod and uses DB_URL*

# --- Docker / prod profile (DB_URL style; use instead of DB_HOST* when SPRING_PROFILES_ACTIVE=prod) ---
# DB_URL=jdbc:postgresql://host:5432/postgres?sslmode=require
# DB_USERNAME=postgres.xxxxx
# DB_PASSWORD=your-database-password

# Uzun təsadüfi string (məs. openssl rand -base64 48 və ya parol meneceri)
JWT_SECRET=buraya-uzun-tesadufi-bir-secret-yaz
JWT_EXPIRATION_MS=86400000

APP_DEMO_MODE=false
APP_SCHEDULER_ENABLED=false

# Frontend URL-ləri (vergüllə, boşluqsuz və ya trim olunur): məs. Vercel/Netlify
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://senin-frontend.vercel.app

# İstəyə bağlı — boş qalsa AI mock/offline işləyir
GEMINI_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Prod-da reverse proxy arxasında: SPRING_PROFILES_ACTIVE=prod
