# --- Local PostgreSQL (default application.yml) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=soc
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=prefer

# --- Supabase (session pooler, port 5432) — set these on your host (Railway, Render, Fly, etc.) ---
# DB_HOST=aws-1-REGION.pooler.supabase.com
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres.YOUR_PROJECT_REF
# DB_PASSWORD=your-database-password
# DB_SSL_MODE=require

SERVER_PORT=8085

JWT_SECRET=replace-with-a-long-random-secret-for-hs256
JWT_EXPIRATION_MS=86400000

APP_DEMO_MODE=false
APP_SCHEDULER_ENABLED=false

GEMINI_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Comma-separated; add your deployed frontend origin(s)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional: SPRING_PROFILES_ACTIVE=prod
